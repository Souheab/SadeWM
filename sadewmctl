#!/usr/bin/env python3
"""sadewmctl — command-line interface for the sadewm Unix socket IPC.

Usage:
  sadewmctl get_state
  sadewmctl view <mask>
  sadewmctl toggleview <mask>
  sadewmctl tag <mask>
  sadewmctl toggletag <mask>

The socket path defaults to /tmp/sadewm.sock and can be overridden with the
SADEWM_SOCKET environment variable.
"""

import argparse
import json
import os
import socket
import sys

SOCKET_PATH = os.environ.get("SADEWM_SOCKET", "/tmp/sadewm.sock")


def send(request: dict) -> dict:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
        try:
            s.connect(SOCKET_PATH)
        except FileNotFoundError:
            sys.exit(f"error: sadewm socket not found at {SOCKET_PATH}")
        except ConnectionRefusedError:
            sys.exit(f"error: sadewm is not running (connection refused at {SOCKET_PATH})")
        s.sendall(json.dumps(request).encode())
        s.shutdown(socket.SHUT_WR)
        data = b""
        while chunk := s.recv(4096):
            data += chunk
    return json.loads(data)


def main():
    p = argparse.ArgumentParser(
        prog="sadewmctl",
        description="Control sadewm via its Unix socket IPC.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("get_state", help="Print current WM state as JSON")
    sp = sub.add_parser("tags_state", help="Print tag states as JSON list")
    sp = sub.add_parser("reload",    help="Reload TOML config file")

    tag_help = {
        "view":       "Show only this tag (replaces current view mask)",
        "toggleview": "Add/remove this tag from the current view",
        "tag":        "Move the focused window exclusively to this tag",
        "toggletag":  "Add/remove this tag from the focused window",
    }
    for name, help_text in tag_help.items():
        sp = sub.add_parser(name, help=help_text)
        sp.add_argument("mask", type=int, help="Tag bitmask (e.g. 4 for tag 3)")

    args = p.parse_args()

    req = {"cmd": args.cmd}
    if args.cmd not in ["get_state", "tags_state", "reload"]:
        req["mask"] = args.mask

    result = send(req)
    print(json.dumps(result, indent=2))
    if not result.get("ok"):
        sys.exit(1)


if __name__ == "__main__":
    main()
