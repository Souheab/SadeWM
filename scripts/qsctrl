#!/usr/bin/env python3
"""
qsctrl — central control dispatcher for the Quickshell bar.

Usage:
    qsctrl tags get               Print tag state as "sel|occ|urg" (awesome-client)
    qsctrl tags view   <N>        Switch to tag N exclusively
    qsctrl tags toggle <N>        Toggle tag N on/off
    qsctrl tags watch             Emit tag state JSON on each change (persistent)

    qsctrl volume get             Print current volume as a bare integer (pamixer)

    qsctrl power lock             Lock the session
    qsctrl power suspend          Suspend the system
    qsctrl power reboot           Reboot the system
    qsctrl power shutdown         Power off the system
    qsctrl power logout           Quit AwesomeWM (log out)

    qsctrl wifi status            Print JSON: {"enabled", "ssid", "signal"}
    qsctrl wifi list              Print JSON array of nearby networks (no rescan)
    qsctrl wifi scan              Rescan then print network list
    qsctrl wifi toggle            Toggle WiFi radio on/off
    qsctrl wifi connect <ssid>    Connect to a known/saved network by SSID
"""

import sys
import subprocess
import json
import socket
import os

SOCKET_PATH = os.environ.get("SADEWM_SOCKET", "/tmp/sadewm.sock")


def sadewm_request(request: dict) -> dict:
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
        try:
            s.connect(SOCKET_PATH)
        except FileNotFoundError:
            return {"ok": False, "error": f"socket not found at {SOCKET_PATH}"}
        except ConnectionRefusedError:
            return {"ok": False, "error": f"connection refused at {SOCKET_PATH}"}
        s.sendall(json.dumps(request).encode())
        s.shutdown(socket.SHUT_WR)
        data = b""
        while chunk := s.recv(4096):
            data += chunk
    return json.loads(data)


def run(cmd: list[str]) -> None:
    """Run a command, inheriting stdout so callers can read output."""
    subprocess.run(cmd, check=False)



def cmd_tags(args: list[str]) -> None:
    if not args:
        print_usage()
        sys.exit(1)

    action = args[0]

    if action == "get":
        res = sadewm_request({"cmd": "get_state"})
        if not res.get("ok"):
            print("||", end="")
            return

        sel = res.get("tag_mask", 0)
        occ = 0
        urg = 0

        for client in res.get("clients", []):
            mask = client.get("tags", 0)
            occ |= mask
            if client.get("urgent"):
                urg |= mask

        print(f"{sel}|{occ}|{urg}")

    elif action == "view" and len(args) >= 2:
        tag_num = int(args[1])
        mask = 1 << (tag_num - 1)
        sadewm_request({"cmd": "view", "mask": mask})

    elif action == "toggleview" and len(args) >= 2:
        tag_num = int(args[1])
        mask = 1 << (tag_num - 1)
        sadewm_request({"cmd": "toggleview", "mask": mask})

    elif action == "state":
        res = sadewm_request({"cmd": "tags_state"})
        print(json.dumps(res))

    elif action == "watch":
        import time
        last = None
        while True:
            res = sadewm_request({"cmd": "tags_state"})
            if res.get("ok"):
                tags_state = res.get("tags_state")
                if tags_state != last:
                    last = tags_state
                    print(json.dumps(res), flush=True)
            time.sleep(0.05)

    else:
        print_usage()
        sys.exit(1)


def cmd_volume(args: list[str]) -> None:
    if not args:
        print_usage()
        sys.exit(1)

    action = args[0]

    if action == "get":
        run(["pamixer", "--get-volume"])
    else:
        print_usage()
        sys.exit(1)


def cmd_power(args: list[str]) -> None:
    if not args:
        print_usage()
        sys.exit(1)

    action = args[0]

    dispatch = {
        "lock":     ["loginctl", "lock-session"],
        "suspend":  ["systemctl", "suspend"],
        "reboot":   ["systemctl", "reboot"],
        "shutdown": ["systemctl", "poweroff"],
        "logout":   ["awesome-client", 'awesome.quit()'],
    }

    if action not in dispatch:
        print_usage()
        sys.exit(1)

    run(dispatch[action])


def cmd_wifi(args: list[str]) -> None:
    import json

    if not args:
        print_usage()
        sys.exit(1)

    action = args[0]

    if action == "status":
        radio = subprocess.run(["nmcli", "radio", "wifi"], capture_output=True, text=True)
        enabled = radio.stdout.strip().lower() == "enabled"

        ssid = ""
        signal = 0
        if enabled:
            dev = subprocess.run(
                ["nmcli", "-t", "-f", "ACTIVE,SSID,SIGNAL", "dev", "wifi"],
                capture_output=True, text=True,
            )
            for line in dev.stdout.strip().splitlines():
                # Format: ACTIVE:SSID:SIGNAL (SSID may contain colons, split from right)
                rparts = line.rsplit(":", 1)
                if len(rparts) == 2:
                    left, sig = rparts
                    lparts = left.split(":", 1)
                    if len(lparts) == 2 and lparts[0] == "yes":
                        ssid = lparts[1].replace("\\:", ":")
                        signal = int(sig) if sig.isdigit() else 0
                        break

        print(json.dumps({"enabled": enabled, "ssid": ssid, "signal": signal}))

    elif action == "list":
        result = subprocess.run(
            ["nmcli", "-t", "-f", "SSID,SIGNAL,SECURITY,ACTIVE", "dev", "wifi", "list", "--rescan", "no"],
            capture_output=True, text=True,
        )
        networks: list[dict] = []
        seen: set[str] = set()
        for line in result.stdout.strip().splitlines():
            if not line:
                continue
            # SECURITY and ACTIVE never contain ':'; split from the right
            parts = line.rsplit(":", 3)
            if len(parts) < 4:
                continue
            ssid_raw, signal_str, security, active = parts
            ssid = ssid_raw.replace("\\:", ":")
            if not ssid or ssid in seen:
                continue
            seen.add(ssid)
            sig = int(signal_str) if signal_str.isdigit() else 0
            networks.append({
                "ssid": ssid,
                "signal": sig,
                "secure": bool(security.strip()),
                "active": active.strip().lower() == "yes",
            })
        networks.sort(key=lambda n: (not n["active"], -n["signal"]))
        print(json.dumps(networks))

    elif action == "scan":
        subprocess.run(["nmcli", "dev", "wifi", "rescan"], capture_output=True)
        cmd_wifi(["list"])

    elif action == "toggle":
        radio = subprocess.run(["nmcli", "radio", "wifi"], capture_output=True, text=True)
        if radio.stdout.strip().lower() == "enabled":
            run(["nmcli", "radio", "wifi", "off"])
        else:
            run(["nmcli", "radio", "wifi", "on"])

    elif action == "connect" and len(args) >= 2:
        run(["nmcli", "device", "wifi", "connect", args[1]])

    else:
        print_usage()
        sys.exit(1)


def print_usage() -> None:
    print(__doc__, file=sys.stderr)


def main() -> None:
    argv = sys.argv[1:]

    if not argv:
        print_usage()
        sys.exit(1)

    group = argv[0]
    rest  = argv[1:]

    if group == "tags":
        cmd_tags(rest)
    elif group == "volume":
        cmd_volume(rest)
    elif group == "power":
        cmd_power(rest)
    elif group == "wifi":
        cmd_wifi(rest)
    elif group == "debug":
        cmd_debug(rest)
    else:
        print_usage()
        sys.exit(1)


def cmd_debug(args: list[str]) -> None:
    if not args:
        print_usage()
        sys.exit(1)

    action = args[0]

    if action == "eval":
        if len(args) < 2:
            print("Usage: qsctrl debug eval <code>")
            sys.exit(1)
        code = args[1]
        try:
            # We explicitly pass -p to target the shell.qml relative to this script's location
            # rather than the system default config. This prevents IPC conflicts.
            shell_path = os.path.abspath(os.path.join(os.path.dirname(__file__), "..", "shell.qml"))
            res = subprocess.run(["quickshell", "-p", shell_path, "ipc", "call", "debug", "evaluate", code], capture_output=True, text=True, check=True)
            print(res.stdout.strip())
        except subprocess.CalledProcessError as e:
            print(f"Error: {e.stderr.strip() or e}")
        except Exception as e:
            print(f"Error: {e}")
    else:
        print_usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
